#Bài1
SELECT 
    oi.order_id,
    p.product_name,
    oi.quantity,
    oi.price
FROM order_items oi
INNER JOIN products p 
ON oi.product_id = p.product_id;

SELECT 
    c.full_name,
    o.order_id
FROM customers c
LEFT JOIN orders o 
ON c.customer_id = o.customer_id;

#Bài2
SELECT 
    p.product_name,
    oi.order_id
FROM order_items oi
RIGHT JOIN products p 
ON oi.product_id = p.product_id;

SELECT 
    full_name AS ContactName,
    phone_number AS PhoneNumber
FROM customers

UNION

SELECT 
    supplier_name AS ContactName,
    contact_phone AS PhoneNumber
FROM suppliers;


# Bài 3 



SELECT product_name, price
FROM products
WHERE supplier_id IN (
    SELECT supplier_id
    FROM suppliers
    WHERE supplier_name = 'Công ty Sữa Việt Nam'
);

SELECT 
    product_name,
    price,
    (SELECT AVG(price) FROM products) AS average_price
FROM products;


#Bài 4 

SELECT order_id
FROM (
    SELECT order_id, SUM(quantity * price) AS total_value
    FROM order_details
    GROUP BY order_id
) AS temp
WHERE total_value > 50000;

SELECT supplier_name
FROM suppliers s
WHERE EXISTS (
    SELECT 1
    FROM products p
    WHERE p.supplier_id = s.supplier_id
);
